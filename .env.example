# ============================================================
# AuditLens — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ── LLM Provider ──────────────────────────────────────────
# Anthropic (default managed cloud)
ANTHROPIC_API_KEY=sk-ant-...
# LLM_PROVIDER=anthropic          # anthropic | bedrock | vertex | openai | together | ollama | vllm

# ── Database ──────────────────────────────────────────────
# PostgreSQL (production) — leave empty for SQLite (local dev)
# DATABASE_URL=postgresql://user:password@host:5432/auditlens

# ── Authentication ────────────────────────────────────────
# JWT_SECRET=<random-32-char-hex>  # Auto-generated if not set — SET THIS in production!

# ── Feature Flags ─────────────────────────────────────────
# PERSIST_DATA=true                # Save data to disk/DB between restarts
# SEED_DEMO=false                  # Load demo data on startup (useful for Railway)
# RESET_ON_START=false             # Wipe DB on each start

# ── Policy Defaults ───────────────────────────────────────
# AMOUNT_TOLERANCE_PCT=5           # % tolerance for amount matching
# PRICE_TOLERANCE_PCT=10           # % tolerance for unit price comparison
# OVER_INVOICE_PCT=2               # % over-invoice threshold
# DUPLICATE_WINDOW_DAYS=90         # Days to check for duplicate invoices

# ── Triage ────────────────────────────────────────────────
# TRIAGE_AUTO_APPROVE_CONFIDENCE=85
# TRIAGE_AUTO_APPROVE_MAX_RISK=40

# ── Logging ───────────────────────────────────────────────
# LOG_LEVEL=INFO                   # DEBUG, INFO, WARNING, ERROR
# LOG_FORMAT=text                  # text (dev) or json (production)

# ── Security ──────────────────────────────────────────────
# ALLOWED_ORIGINS=https://yourdomain.com  # Comma-separated. Default: * (dev only!)

# ── Together.ai (for fine-tuning) ─────────────────────────
# TOGETHER_API_KEY=...

# ── Server ────────────────────────────────────────────────
# PORT=8000
